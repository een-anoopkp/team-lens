# Exported CSVs land in web/<dashboard>/ — data, not code
web/*/*.csv

# clasp credentials & local settings — never commit
.clasprc.json
apps-script/*/.clasp.json

# Editor / OS cruft
.DS_Store
*.swp
.vscode/
.idea/

# Claude Code workspace artifacts (auto-symlinked skills, etc.)
.claude/

# Node junk if anything pulls in deps later
node_modules/

# Local env / logs / secrets
.env
.env.local
*.log

# Python build artifacts
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.venv/

# Dist
dist/
