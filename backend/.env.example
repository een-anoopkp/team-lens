FULL_SCAN_CRON=0 3 * * 0

# --- Logging --------------------------------------------------------------------
LOG_LEVEL=INFO

# --- Operational ----------------------------------------------------------------
TEAM_REGION=IN
APP_HOST=0.0.0.0
APP_PORT=8000
